# mount point    fstype    device                device2               flags
# System partitions - for erofs partition you can also specify ext4 fstype (Huawei strange !!)
/cache                 ext4     /dev/block/bootdevice/by-name/cache           flags=backup=1
/splash2               ext4    /dev/block/bootdevice/by-name/splash2     flags=backup=1

/cust                  erofs    /dev/block/bootdevice/by-name/cust            flags=backup=1;display="Cust";fsflags=ro
/data                  f2fs     /dev/block/bootdevice/by-name/userdata        flags=backup=1;encryptable=footer
/odm                   erofs    /dev/block/bootdevice/by-name/odm             flags=backup=1;display="Odm"
/odm_image             emmc     /dev/block/bootdevice/by-name/odm             flags=backup=1;display="Odm Image";flashimg
/product               erofs    /dev/block/bootdevice/by-name/product         flags=backup=1;fsflags=ro
/product_image         emmc     /dev/block/bootdevice/by-name/product         flags=backup=1;display="Product Image";flashimg
/system                erofs    /dev/block/bootdevice/by-name/system          flags=backup=1;fsflags=ro
/system_image          emmc     /dev/block/bootdevice/by-name/system          flags=backup=1;display="System Image";flashimg
/vendor                erofs    /dev/block/bootdevice/by-name/vendor          flags=backup=1;fsflags=ro
/vendor_image          emmc     /dev/block/bootdevice/by-name/vendor          flags=backup=1;display="Vendor Image";flashimg
/version               erofs    /dev/block/bootdevice/by-name/version         flags=backup=1;fsflags=ro
/version_image         emmc     /dev/block/bootdevice/by-name/version         flags=backup=1;display="Version Image";flashimg
/preload               erofs    /dev/block/bootdevice/by-name/preload         flags=backup=1;fsflags=ro
/preload_image         emmc     /dev/block/bootdevice/by-name/preload         flags=backup=1;display="Preload Image";flashimg
/kernel                emmc     /dev/block/bootdevice/by-name/kernel          flags=backup=1;flashimg
/ramdisk               emmc     /dev/block/bootdevice/by-name/ramdisk         flags=backup=1;flashimg
/preas                 erofs    /dev/block/bootdevice/by-name/preas           flags=backup=1;display="Preas";wipeingui;fsflags=ro
/preavs                erofs    /dev/block/bootdevice/by-name/preavs          flags=backup=1;display="Preavs";wipeingui;fsflags=ro


# Protected partitions
/oeminfo     emmc    /dev/block/bootdevice/by-name/oeminfo     flags=backup=1;display="OEM Info";flashimg
/misc        emmc    /dev/block/bootdevice/by-name/misc        flags=display="Misc"

/sec_storage ext4    /dev/block/bootdevice/by-name/secure_storage     flags=display="Secure Storage";fsflags="rw,nosuid,nodev,discard,auto_da_alloc,mblk_io_submit,data=journal,context=u:object_r:teecd_data_file:s0"
/vbmeta      emmc    /dev/block/bootdevice/by-name/vbmeta      flags=backup=1;display="VBMeta";flashimg
/nvme        emmc    /dev/block/bootdevice/by-name/nvme        flags=backup=1;display="NVME";flashimg

# FRP + Misc
/frp         emmc    /dev/block/bootdevice/by-name/frp        flags=backup=1;display="FRP";wipeingui;flashimg
/misc        emmc    /dev/block/bootdevice/by-name/misc       flags=backup=1;display="Misc";wipeingui

# Modem partition
/modemnvm_cust		emmc	/dev/block/bootdevice/by-name/modemnvm_cust	flags=backup=1;flashimg
/modemnvm_update	emmc	/dev/block/bootdevice/by-name/modemnvm_update	flags=backup=1;flashimg
/modem_fw		emmc	/dev/block/bootdevice/by-name/modem_fw	flags=backup=1;display="Modem Firmware";flashimg


# Recovery partitions
/recovery_ramdisk	emmc	/dev/block/bootdevice/by-name/recovery_ramdisk  	flags=display="Recovery Ramdisk";backup=1;flashimg
/recovery_vbmeta	emmc	/dev/block/bootdevice/by-name/recovery_vbmeta		flags=display="Recovery Vbmeta ";backup=1;flashimg
/recovery_vendor	emmc	/dev/block/bootdevice/by-name/recovery_vendor		flags=display="Recovery Vendor";backup=1;flashimg

# ERecovery partitions
/erecovery_ramdisk	emmc	/dev/block/bootdevice/by-name/erecovery_ramdisk		flags=display="eRecovery Ramdisk";backup=1;flashimg
/erecovery_kernel	emmc	/dev/block/bootdevice/by-name/erecovery_kernel		flags=display="eRecovery Kernel";backup=1;flashimg
/erecovery_vbmeta	emmc	/dev/block/bootdevice/by-name/erecovery_vbmeta		flags=display="eRecovery Vbmeta";backup=1;flashimg
/erecovery_vendor	emmc	/dev/block/bootdevice/by-name/erecovery_vendor		flags=display="eRecovery Vendor";backup=1;flashimg

# External storage
/external_sd		auto	/dev/block/mmcblk1p1  /dev/block/mmcblk1		flags=display="Micro SDcard";storage;wipeingui;removable


